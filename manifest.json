{
  "manifest_version": 3,
  "name": "Shopee Captcha Solver",
  "description": "Automatically bypass any Shopee captcha",
  "version": "2.3",
  "action": {
    "default_popup": "hello.html",
    "default_icon": "logo_icon_black_bg.png"
  },
  "content_scripts": [
    {
      "matches": [
		"<all_urls>"
      ],
      "all_frames": false,
      "js": [
        "script.js"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "greg@sadcaptcha.com"
    }
  }
}
